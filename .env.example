# yt-dlp 可执行文件路径
# 必须使用 nightly 版本(支持 --js-runtimes node,破解 YouTube SABR / n-challenge)
# 安装: pip install --user --pre yt-dlp yt-dlp-ejs
# macOS 示例: ~/Library/Python/3.14/bin/yt-dlp
# Linux 通常在 ~/.local/bin/yt-dlp
YT_DLP_PATH=~/Library/Python/3.14/bin/yt-dlp

# Flask 服务监听地址
HOST=0.0.0.0
PORT=8080

# 最大并发下载任务数
MAX_CONCURRENT=1

# HTTP 分块大小(仅在 aria2c 缺失时生效;对应 yt-dlp --http-chunk-size)
# 实测: 该参数对 YouTube 音频单连接限流几乎无效(25 vs 29 KiB/s),
#       音频慢的根因是 googlevideo 按单连接码率限流。真正的解法是 aria2c 并发。
HTTP_CHUNK_SIZE=10M

# aria2c 可执行文件路径(强烈推荐安装)
# 安装: brew install aria2  /  apt install aria2
# 留空则自动 which aria2c;找不到则回退到 HTTP_CHUNK_SIZE 模式
ARIA2C_PATH=

# aria2c 并发连接数(对应 -x / -s)
# 每条连接独享 googlevideo 的限流配额,多连接叠加 ≈ 突破音频速率限制
# 实测: 16 条连接把音频从 ~40 KiB/s 拉到 ~5 MiB/s(~120x)
ARIA2C_CONNECTIONS=16
